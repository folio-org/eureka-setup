# folio-netcat and folio-vault are always built locally (no registry namespace).
# The tags below are only local labels; rebuild after a CLI upgrade with: -o then buildSystem.
FOLIO_NETCAT_VERSION=latest
FOLIO_VAULT_VERSION=latest

# folio-keycloak and folio-kong: upstream FOLIO images.
# Defaults track the folioci snapshot namespace at :latest, matching the rest of the
# stack (platform-lsp snapshot descriptor, sidecar). For a reproducible pin, switch a
# namespace to folioorg with a release version, or keep folioci with a *-SNAPSHOT.* tag.
FOLIO_KEYCLOAK_NAMESPACE=folioci
FOLIO_KEYCLOAK_VERSION=latest
FOLIO_KONG_NAMESPACE=folioci
FOLIO_KONG_VERSION=latest

# Dozzle
DOZZLE_VERSION=v10.0.0

# Postgres
POSTGRES_VERSION=16.11

# Nginx
NGINX_VERSION=1.29.4

# Kafka
KAFKA_VERSION=4.1.1
KAFKA_UI_VERSION=v1.4.2

# OpenSearch
OPENSEARCH_VERSION=3.5.0
OPENSEARCH_DASHBOARD_VERSION=3.5.0

# MinIO
MINIO_VERSION=RELEASE.2025-09-07T16-13-09Z
MINIO_MC_VERSION=RELEASE.2025-08-13T08-35-41Z

# File transfer
FTP_SERVER_VERSION=0.9.2

# OpenTelemetry
OTEL_LGTM_VERSION=0.8.1